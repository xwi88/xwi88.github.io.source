</span></span><span class="line"><span class="cl">    <span class="nx">site_pv_pre</span> <span class="p">=</span> <span class="s1">&#39;&lt;i class=&#34;fa fa-eye&#34;&gt;&lt;/i&gt;&#39;</span>
