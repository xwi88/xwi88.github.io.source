<td class="lntd">
<pre tabindex="0" class="chroma"><code class="language-bash" data-lang="bash"><span class="line"><span class="cl"><span class="c1"># vi /etc/hosts</span>
</span></span><span class="line"><span class="cl">xxx github.global.ssl.fastly.net
